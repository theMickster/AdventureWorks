{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "AdventureWorks Aspire",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-aspire",
      "program": "${workspaceFolder}/tools/aspire/AdventureWorks.AppHost/bin/Debug/net10.0/AdventureWorks.AppHost.dll",
      "args": [],
      "cwd": "${workspaceFolder}/tools/aspire/AdventureWorks.AppHost",
      "stopAtEntry": false,
      "justMyCode": true,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "DOTNET_ENVIRONMENT": "Development"
      }
    },
    {
      "name": "AdventureWorks API",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-api",
      "program": "${workspaceFolder}/apps/api-dotnet/src/AdventureWorks.API/bin/Debug/net10.0/AdventureWorks.API.dll",
      "args": [],
      "cwd": "${workspaceFolder}/apps/api-dotnet/src/AdventureWorks.API",
      "stopAtEntry": false,
      "justMyCode": true,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },
    {
      "name": "AdventureWorks API (PlaywrightTesting)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-api",
      "program": "${workspaceFolder}/apps/api-dotnet/src/AdventureWorks.API/bin/Debug/net10.0/AdventureWorks.API.dll",
      "args": [],
      "cwd": "${workspaceFolder}/apps/api-dotnet/src/AdventureWorks.API",
      "stopAtEntry": false,
      "justMyCode": true,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "PlaywrightTesting",
        // Plain HTTP, matching pipelines/templates/e2e.yml — HTTPS here triggers a macOS
        // Kestrel HTTP/2-over-TLS teardown bug (SslStream "Bad address") under Playwright's
        // connection churn. environment.playwright.ts points at this same origin.
        "ASPNETCORE_URLS": "http://localhost:5000"
      }
    },
    {
      "name": "AdventureWorks Web",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:4200",
      "webRoot": "${workspaceFolder}/apps/angular-web/apps/adventureworks-web",
      "preLaunchTask": "serve-web",
      "sourceMaps": true
    }
  ],
  "compounds": [
    {
      "name": "Full Stack: API + Web",
      "configurations": ["AdventureWorks API", "AdventureWorks Web"],
      "stopAll": true,
      "presentation": {
        "group": "fullstack",
        "order": 1
      }
    }
  ]
}
