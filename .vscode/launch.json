{
  // The .NET (coreclr) debugger has no launch.json field for filtering exception
  // types. Expected exceptions thrown into FluentValidation/KeyNotFound flows are
  // caught by ExceptionHandlerMiddleware, but the debugger still breaks on the
  // "User-Unhandled" exception filter. Configure the ignore list in the
  // Breakpoints panel (Run & Debug view).
  //
  // Setup: apps/api-dotnet/.claude/guides/debugging-guide.md
  "version": "0.2.0",
  "configurations": [
    {
      "name": "AdventureWorks API",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-api",
      "program": "${workspaceFolder}/apps/api-dotnet/src/AdventureWorks.API/bin/Debug/net10.0/AdventureWorks.API.dll",
      "args": [],
      "cwd": "${workspaceFolder}/apps/api-dotnet/src/AdventureWorks.API",
      "stopAtEntry": false,
      "justMyCode": true,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    }
  ]
}
