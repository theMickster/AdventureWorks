{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  },
  "ConnectionStrings": {
    "AdventureWorksDev": "Server=MySqlServer;Database=AdventureWorksDev;",
    "AdventureWorks_E2E": "Server=MySqlServer;Database=AdventureWorks_E2E;"
  },
  "DbReset": {
    "SnapshotSource": "AdventureWorksDev",
    "DefaultTarget": "AdventureWorks_E2E",
    "BaselinePath": "tools/console-apps/AdventureWorks.DbReset.Console/baselines/AdventureWorks_baseline.bak",
    "TargetNamePattern": "^AdventureWorks_(E2E|Test|Load)([A-Za-z0-9_]*)?$",
    "DbUpProjectPath": "database/dbup/AdventureWorks.DbUp",
    "SourceMarker": {
      "Property": "dbreset.role",
      "Value": "source"
    }
  }
}
