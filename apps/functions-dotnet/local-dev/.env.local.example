# Copy to .env.local (gitignored) and fill in MSSQL_SA_PASSWORD before running the local Service Bus emulator.
# MSSQL_SA_PASSWORD must match the SA password of the pre-existing 'tosk-mssql' container (localhost:1433) — the emulator uses it as its SQL backend and must already be running.
# ACCEPT_EULA=Y acknowledges the Service Bus emulator EULA — required to run the emulator container.
ACCEPT_EULA=Y
MSSQL_SA_PASSWORD=
