  "item": [
    {
      "name": "Product Reviews",
      "item": [
        {
          "name": "List By Product - Has Reviews",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status should be OK\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "var response = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Response should have correct structure\", function() {\r",
                  "    pm.expect(response).to.exist;\r",
                  "    pm.expect(response.results).to.exist;\r",
                  "    pm.expect(response.pageNumber).to.exist;\r",
                  "    pm.expect(response.pageSize).to.exist;\r",
                  "    pm.expect(response.totalPages).to.exist;\r",
                  "    pm.expect(response.totalRecords).to.exist;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response should contain at least 2 reviews for product 937\", function() {\r",
                  "    pm.expect(response.results.length).to.be.at.least(2);\r",
                  "    pm.expect(response.results[0].productId).to.eql(937);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{adventureWorksApi}}/{{apiVersion}}/products/937/reviews",
              "host": [
                "{{adventureWorksApi}}"
              ],
              "path": [
                "{{apiVersion}}",
                "products",
                "937",
                "reviews"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Statistics - Has Reviews",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status should be OK\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "const productId = 937\r",
                  "var response = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Should return correct aggregate statistics\", function() {\r",
                  "    pm.expect(response.productId).to.eql(productId);\r",
                  "    pm.expect(response.totalReviews).to.eql(2);\r",
                  "    pm.expect(response.averageRating).to.exist;\r",
                  "    pm.expect(response.ratingDistribution).to.exist;\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{adventureWorksApi}}/{{apiVersion}}/products/937/reviews/statistics",
              "host": [
                "{{adventureWorksApi}}"
              ],
              "path": [
                "{{apiVersion}}",
                "products",
                "937",
                "reviews",
                "statistics"
              ]
            }
          },
          "response": []
        }
