    {
      "name": "Work Orders",
      "item": [
        {
          "name": "Work Orders List - Zero Params",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status should be OK\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "var response = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Response should have correct structure\", function() {\r",
                  "    pm.expect(response).to.exist;\r",
                  "    pm.expect(response.results).to.be.an(\"array\");\r",
                  "    pm.expect(response.pageNumber).to.exist;\r",
                  "    pm.expect(response.pageSize).to.exist;\r",
                  "    pm.expect(response.totalPages).to.exist;\r",
                  "    pm.expect(response.totalRecords).to.exist;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Defaults to page 1, page size 25\", function() {\r",
                  "    pm.expect(response.pageNumber).to.eq(1);\r",
                  "    pm.expect(response.pageSize).to.eq(25);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Each result should have required work order fields\", function() {\r",
                  "    response.results.forEach(function(workOrder) {\r",
                  "        pm.expect(workOrder.workOrderId).to.be.a(\"number\");\r",
                  "        pm.expect(workOrder.productId).to.be.a(\"number\");\r",
                  "        pm.expect(workOrder.productName).to.be.a(\"string\");\r",
                  "        pm.expect(workOrder.orderedQty).to.be.a(\"number\");\r",
                  "        pm.expect(workOrder.stockedQty).to.be.a(\"number\");\r",
                  "        pm.expect(workOrder.scrappedQty).to.be.a(\"number\");\r",
                  "        pm.expect(workOrder.yieldRate).to.be.a(\"number\");\r",
                  "        pm.expect(workOrder.startDate).to.exist;\r",
                  "        pm.expect(workOrder.dueDate).to.exist;\r",
                  "        pm.expect(workOrder.isCompletedLate).to.be.a(\"boolean\");\r",
                  "    });\r",
                  "});\r"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
