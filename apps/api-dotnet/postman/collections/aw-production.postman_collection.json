      "name": "Products",
      "item": [
        {
          "name": "List",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status should be OK\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "var response = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Response should have correct structure\", function() {\r",
                  "    pm.expect(response).to.exist;\r",
                  "    pm.expect(response.results).to.exist;\r",
                  "    pm.expect(response.pageNumber).to.exist;\r",
                  "    pm.expect(response.pageSize).to.exist;\r",
                  "    pm.expect(response.totalPages).to.exist;\r",
                  "    pm.expect(response.totalRecords).to.exist;\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
