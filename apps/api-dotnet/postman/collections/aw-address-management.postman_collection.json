              "name": "Address - Null body",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test(\"Response should be 400 & have a body\", function () {\r",
                      "     pm.response.to.be.badRequest;\r",
                      "     pm.response.to.be.withBody;     \r",
                      "});\r",
                      "\r",
                      "pm.test(\"Response contain correct error\", function() {    \r",
                      "    var error = pm.response.text();\r",
                      "    pm.expect(error).to.contain(\"The address input model cannot be null.\");\r",
                      "});"
                    ],
                    "type": "text/javascript",
                    "packages": {}
                  }
                }
