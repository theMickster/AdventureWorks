		{
			"name": "List",
			"id": "315955fc-efa1-4d74-939e-7f6036e6117c",
			"item": [
				{
					"name": "Get Vendors (default list)",
					"id": "0a21c061-f08c-4523-aefe-f7770d391be1",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Has X-Correlation-Id header\", function () {",
									"    pm.response.to.have.header(\"X-Correlation-Id\");",
									"});",
									"",
									"var body = pm.response.json();",
									"",
									"pm.test(\"Response has paginated shape\", function () {",
									"    pm.expect(body.results).to.be.an(\"array\");",
									"    pm.expect(body).to.have.property(\"pageNumber\");",
									"    pm.expect(body).to.have.property(\"pageSize\");",
									"    pm.expect(body).to.have.property(\"totalRecords\");",
									"});",
									"",
									"pm.test(\"Defaults to pageSize 25\", function () {",
									"    pm.expect(body.pageSize).to.eql(25);",
									"});",
									"",
									"pm.test(\"Each result has required fields\", function () {",
									"    if (body.results.length === 0) return;",
									"    var r = body.results[0];",
									"    pm.expect(r).to.have.property(\"vendorId\");",
									"    pm.expect(r).to.have.property(\"name\");",
									"    pm.expect(r).to.have.property(\"accountNumber\");",
									"    pm.expect(r).to.have.property(\"creditRatingLabel\");",
									"    pm.expect(r).to.have.property(\"preferredVendorStatus\");",
									"    pm.expect(r).to.have.property(\"activeFlag\");",
									"    pm.expect(r).to.have.property(\"totalSpend\");",
									"    pm.expect(r).to.have.property(\"poCount\");",
									"    pm.expect(r).to.have.property(\"isHighRisk\");",
									"});",
									"",
									"pm.test(\"Results are ordered by totalSpend descending\", function () {",
									"    for (var i = 1; i < body.results.length; i++) {",
									"        pm.expect(body.results[i - 1].totalSpend).to.be.at.least(body.results[i].totalSpend);",
									"    }",
									"});",
									"",
									"pm.test(\"isHighRisk is only true for creditRatingLabel Average or Below Average\", function () {",
									"    body.results.forEach(function (r) {",
									"        if (r.isHighRisk) {",
									"            pm.expect([\"Average\", \"Below Average\"]).to.include(r.creditRatingLabel);",
									"        }",
									"    });",
									"});"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{adventureWorksApi}}/{{apiVersion}}/vendors?pageNumber=1&pageSize=25",
							"host": [
								"{{adventureWorksApi}}"
							],
							"path": [
								"{{apiVersion}}",
								"vendors"
							],
							"query": [
								{
									"key": "pageNumber",
									"value": "1"
								},
								{
									"key": "pageSize",
									"value": "25"
								}
							]
						}
					},
					"response": []
				},
