							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Has X-Correlation-Id header\", function () {",
									"    pm.response.to.have.header(\"X-Correlation-Id\");",
									"});",
									"",
									"var body = pm.response.json();",
									"",
									"pm.test(\"Results is an empty array\", function () {",
									"    pm.expect(body.results).to.be.an(\"array\").that.is.empty;",
									"});",
									"",
									"pm.test(\"totalRecords is still reported\", function () {",
									"    pm.expect(body.totalRecords).to.be.a(\"number\");",
									"});"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						}
