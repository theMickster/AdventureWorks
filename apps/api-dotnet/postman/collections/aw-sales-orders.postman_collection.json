              "name": "Sales Orders List - Zero Params",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test(\"Status should be OK\", function () {\r",
                      "    pm.response.to.have.status(200);\r",
                      "});\r",
                      "\r",
                      "var response = pm.response.json();\r",
                      "\r",
                      "pm.test(\"Response should have correct structure\", function() {\r",
                      "    pm.expect(response).to.exist;\r",
                      "    pm.expect(response.results).to.be.an(\"array\");\r",
                      "    pm.expect(response.pageNumber).to.exist;\r",
                      "    pm.expect(response.pageSize).to.exist;\r",
                      "    pm.expect(response.totalPages).to.exist;\r",
                      "    pm.expect(response.totalRecords).to.exist;\r",
                      "    pm.expect(response).to.have.property(\"hasPreviousPage\");\r",
                      "    pm.expect(response).to.have.property(\"hasNextPage\");\r",
                      "});\r",
                      "\r",
                      "pm.test(\"Response should include correct paging information\", function() {\r",
                      "    pm.expect(response.pageNumber).to.eq(1);\r",
                      "    pm.expect(response.pageSize).to.eq(10);\r",
                      "    pm.expect(response.totalRecords).to.eq(31465);\r",
                      "    pm.expect(response.totalPages).to.eq(3147);\r",
                      "    pm.expect(response.hasPreviousPage).to.be.false;\r",
                      "    pm.expect(response.hasNextPage).to.be.true;\r",
                      "});\r",
                      "\r",
                      "pm.test(\"Results array should have 10 items\", function() {\r",
                      "    pm.expect(response.results.length).to.eq(10);\r",
                      "});\r",
                      "\r",
                      "pm.test(\"Each result should have required sales order fields\", function() {\r",
                      "    response.results.forEach(function(order) {\r",
                      "        pm.expect(order.salesOrderId).to.be.a(\"number\");\r",
                      "        pm.expect(order.salesOrderNumber).to.be.a(\"string\");\r",
                      "        pm.expect(order.orderDate).to.exist;\r",
                      "        pm.expect(order.status).to.be.a(\"number\");\r",
                      "        pm.expect(order.statusDescription).to.be.a(\"string\");\r",
                      "        pm.expect(order.totalDue).to.be.a(\"number\");\r",
                      "        pm.expect(order.customerName).to.be.a(\"string\");\r",
                      "    });\r",
                      "});"
                    ],
