                    "exec": [
                      "pm.test(\"Status should be OK\", function () {\r",
                      "    pm.response.to.have.status(200);\r",
                      "});\r",
                      "\r",
                      "var response = pm.response.json();\r",
                      "\r",
                      "pm.test(\"Response should have sales order header fields\", function() {\r",
                      "    pm.expect(response.salesOrderId).to.eq(43659);\r",
                      "    pm.expect(response.salesOrderNumber).to.eq(\"SO43659\");\r",
                      "    pm.expect(response.orderDate).to.exist;\r",
                      "    pm.expect(response.dueDate).to.exist;\r",
                      "    pm.expect(response.status).to.be.a(\"number\");\r",
                      "    pm.expect(response.statusDescription).to.be.a(\"string\");\r",
                      "    pm.expect(response.subTotal).to.be.a(\"number\");\r",
                      "    pm.expect(response.taxAmt).to.be.a(\"number\");\r",
                      "    pm.expect(response.freight).to.be.a(\"number\");\r",
                      "    pm.expect(response.totalDue).to.be.a(\"number\");\r",
                      "});\r",
                      "\r",
                      "pm.test(\"Response should have line items\", function() {\r",
                      "    pm.expect(response.lineItems).to.be.an(\"array\");\r",
                      "    pm.expect(response.lineItems.length).to.be.above(0);\r",
                      "    response.lineItems.forEach(function(item) {\r",
                      "        pm.expect(item.salesOrderDetailId).to.be.a(\"number\");\r",
                      "        pm.expect(item.productName).to.be.a(\"string\");\r",
                      "        pm.expect(item.orderQty).to.be.a(\"number\");\r",
                      "        pm.expect(item.unitPrice).to.be.a(\"number\");\r",
                      "        pm.expect(item.lineTotal).to.be.a(\"number\");\r",
                      "    });\r",
                      "});\r",
                      "\r",
                      "pm.test(\"Response should have bill-to and ship-to addresses\", function() {\r",
                      "    pm.expect(response.billToAddress).to.exist;\r",
                      "    pm.expect(response.billToAddress.addressLine1).to.be.a(\"string\");\r",
                      "    pm.expect(response.billToAddress.city).to.be.a(\"string\");\r",
                      "    pm.expect(response.billToAddress.stateProvince).to.be.a(\"string\");\r",
