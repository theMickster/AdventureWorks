{
  "name": "hr-feature-org-chart",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/hr/feature-org-chart/src",
  "prefix": "aw",
  "projectType": "library",
  "tags": ["type:feature", "scope:hr"],
  "targets": {
    "build": {
      "executor": "@nx/angular:ng-packagr-lite",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "project": "libs/hr/feature-org-chart/ng-package.json",
        "tsConfig": "libs/hr/feature-org-chart/tsconfig.lib.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "libs/hr/feature-org-chart/tsconfig.lib.prod.json"
        },
        "development": {}
      },
      "defaultConfiguration": "production"
    },
    "test": {
      "executor": "@nx/angular:unit-test",
      "options": {
        "reporters": ["junit", "default"],
        "outputFile": "libs/hr/feature-org-chart/test-results/junit.xml"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
