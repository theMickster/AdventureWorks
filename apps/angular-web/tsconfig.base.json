{
  "compilerOptions": {
    "rootDir": ".",
    "baseUrl": ".",
    "sourceMap": true,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "target": "es2022",
    "module": "preserve",
    "lib": ["es2022", "dom"],
    "strict": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "paths": {
      "@adventureworks-web/shared/ui": ["./libs/shared/ui/src/index.ts"],
      "@adventureworks-web/shared/util": ["./libs/shared/util/src/index.ts"],
      "@adventureworks-web/shared/app-layout": ["./libs/shared/app-layout/src/index.ts"],
      "@adventureworks-web/shared/data-access": ["./libs/shared/data-access/src/index.ts"],
      "@adventureworks-web/sales/data-access": ["./libs/sales/data-access/src/index.ts"],
      "@adventureworks-web/hr/data-access": ["./libs/hr/data-access/src/index.ts"],
      "@adventureworks-web/sales/feature-stores": ["./libs/sales/feature-stores/src/index.ts"],
      "@adventureworks-web/sales/feature-sales-persons": ["./libs/sales/feature-sales-persons/src/index.ts"],
      "@adventureworks-web/sales/feature-orders": ["./libs/sales/feature-orders/src/index.ts"],
      "@adventureworks-web/sales/feature-dashboard": ["./libs/sales/feature-dashboard/src/index.ts"],
      "@adventureworks-web/hr/feature-departments": ["./libs/hr/feature-departments/src/index.ts"],
      "@adventureworks-web/hr/feature-employees": ["./libs/hr/feature-employees/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
